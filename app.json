{
  "expo": {
    "name": "Porras Mundial 2026",
    "slug": "porras-mundial-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "porras-mundial",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.porrasmundial.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5F7"
      },
      "package": "com.porrasmundial.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68ebd1f3-1b3e-427a-8931-4af5f6e63288"
      }
    }
  }
}
